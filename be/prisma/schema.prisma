generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DeviceData {
  id         String   @id @default(uuid())
  macAddress String
  message    String
  time       DateTime
  gpsLat     Float?
  gpsLon     Float?
  meta       Json?
  receivedAt DateTime @default(now())

  @@index([macAddress, time])
  @@index([receivedAt])
}

