# Loaded at startup via `import "dotenv/config"` in src/index.ts
DATABASE_URL="postgresql://user:password@localhost:5432/echo?schema=public"

# Firestore (Admin): download service account JSON from Firebase console →
# Project Settings → Service Accounts → Generate new private key, then paste inline:
FIREBASE_PROJECT_ID="echo-5beed"
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"echo-5beed","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@echo-5beed.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}'
# FIRESTORE_EMULATOR_HOST="127.0.0.1:8080"  # local emulator only
# GEMINI_API_KEY=   # required for AI triage on POST /api/data
GEMINI_MODEL="gemini-2.0-flash"
TRIAGE_ENABLED="true"
TRIAGE_NEARBY_RADIUS_M="500"

# CORS: `true` reflects request origin (dev). Set a single origin string in production.
# CORS_ORIGIN="true"

# --- Rescuer JWT provisioning (RS256) ---
# Generate a PKCS#8 PEM (2048-bit RSA), then paste as one line using \n for newlines:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out /tmp/jwt.pem
#   openssl pkcs8 -topk8 -inform PEM -outform PEM -nocrypt -in /tmp/jwt.pem -out /tmp/jwt_pkcs8.pem
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----"
#
# ADMIN_API_KEY=use-a-long-random-secret-in-production
# JWT_ISSUER=echo
# JWT_AUDIENCE=echo-rescuer
# JWT_KEY_ID=echo-provisioning-1
# JWT_DEFAULT_EXPIRES_SECONDS=315360000
# JWT_MAX_EXPIRES_SECONDS=315360000
