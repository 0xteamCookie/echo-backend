NODE_ENV=development
PORT=3000

# ── Firebase (required) ─────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-gcp-project-id
# Paste the downloaded SA JSON as a single line. Escape each newline in the
# private_key as \n (JSON-escape). Easy way:
#   node -e 'console.log(JSON.stringify(require("/absolute/path/sa.json")))'
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"...","universe_domain":"googleapis.com"}'

# ── Mobile ingest shared secret (required; must match Flutter dart-defines.json) ──
# Generate: openssl rand -hex 32
BEACON_INGEST_TOKEN=replace-with-32-byte-hex-secret

# ── Dashboard / admin (required in prod) ────────────────────────────────────
# Generate: openssl rand -base64 32
DASHBOARD_JWT_SECRET=replace-with-long-random-secret
SUPER_ADMIN_EMAIL=admin@your-domain.com
SUPER_ADMIN_PASSWORD=replace-with-strong-password

# ── Provisioning (required to issue rescuer tokens) ─────────────────────────
# Reserved for future out-of-band / server-to-server provisioning callers.
# The browser admin UI does NOT send this header — the `/api/provision/token`
# endpoint is gated by the dashboard JWT `provision:issue` permission
# (super_admin role) which is already a sufficient single-gate.
# Generate: openssl rand -hex 32
ADMIN_API_KEY=replace-with-long-random-secret
# JWT signing key is derived from FIREBASE_SERVICE_ACCOUNT_JSON above — no separate key needed.

# ── AI triage (Gemini API key) ───────────────────────────────────────────────
# Get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-3.1-flash-lite

# ── Feature flags (off in dev by default, on in prod) ───────────────────────
TRIAGE_ENABLED=true
APP_CHECK_ENABLED=false       # set true once Firebase App Check is configured
FCM_ENABLED=true
TRANSLATION_ENABLED=true
TRANSLATION_TARGET_LANGS=en,hi,bn,ta,te,mr,gu,kn,ml,pa
PUBSUB_ENABLED=true
BIGQUERY_ENABLED=true
DISTANCE_MATRIX_ENABLED=true

# ── Pub/Sub push auth (required when PUBSUB_ENABLED=true) ───────────────────
# Must match the ?token= query param on the GCP push subscription URL.
# Generate: openssl rand -hex 32
PUBSUB_PUSH_TOKEN=replace-with-32-byte-hex-secret

# ── Google Maps server-side key (required when DISTANCE_MATRIX_ENABLED=true) ─
# Enable "Distance Matrix API" on this key in Google Cloud Console.
GOOGLE_MAPS_API_KEY=AIzaSy...

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call the API. The admin UI (fe-admin)
# calls this backend directly from the browser, so its deployed origin MUST
# be listed here. In local dev, run fe-admin on a different port than `be`
# (e.g. `next dev -p 3001`) and include that port below.
CORS_ORIGINS=http://localhost:3001,https://your-admin-domain.com
