# ── Backend API (required) ──────────────────────────────────────────────────
# Public URL of the `be` Express backend. The admin UI calls it directly from
# the browser, so this value is bundled into the client (hence NEXT_PUBLIC_).
# The backend must list this admin origin in its CORS_ORIGINS env var.
NEXT_PUBLIC_BACKEND_URL="http://localhost:3000"

# ── Firebase client SDK (required for realtime Firestore onSnapshot) ─────────
# These vars are prefixed NEXT_PUBLIC_ so they are bundled into the browser.
# Find them in Firebase console → Project Settings → Your apps → Web app config.
# If omitted, the admin UI falls back to REST polling for heatmap data.
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSy..."
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="000000000000"
NEXT_PUBLIC_FIREBASE_APP_ID="1:000000000000:web:abc123"

# ── Google Maps Platform (P2-2) ─────────────────────────────────────────────
# Client-side key used by the admin heatmap and announcement map. Must have
# the Maps JavaScript API + Places API (optional) enabled. Restrict to your
# admin host via HTTP referrer restrictions in the Google Cloud console.
# If missing, the admin UI renders a "Configure Google Maps API key" panel
# instead of crashing.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
